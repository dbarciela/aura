<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Ignore CSRF warning for ProxyController as it acts as a stateless API proxy without session auth -->
    <Match>
        <Class name="io.github.dbarciela.aura.controller.ProxyController" />
        <Bug pattern="SPRING_CSRF_UNRESTRICTED_REQUEST_MAPPING" />
    </Match>
</FindBugsFilter>
